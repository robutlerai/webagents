{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://uamp.dev/schemas/events.json",
  "title": "UAMP Events",
  "description": "JSON Schema for UAMP protocol events",
  
  "definitions": {
    "baseEvent": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "event_id": { "type": "string" },
        "timestamp": { "type": "integer" },
        "session_id": { "type": "string", "description": "Session scope (required for multiplexed connections)" }
      },
      "required": ["type", "event_id"]
    },
    
    "modality": {
      "type": "string",
      "enum": ["text", "audio", "image", "video", "file"]
    },
    
    "audioFormat": {
      "type": "string",
      "enum": ["pcm16", "g711_ulaw", "g711_alaw", "mp3", "opus", "wav", "webm", "aac"]
    },
    
    "voiceConfig": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "voice_id": { "type": "string" },
        "name": { "type": "string" },
        "speed": { "type": "number", "minimum": 0.5, "maximum": 2.0 },
        "pitch": { "type": "number" },
        "language": { "type": "string" },
        "extensions": { "type": "object" }
      }
    },
    
    "responseFormat": {
      "type": "object",
      "description": "Controls the output format of the model response (structured output)",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "json_object", "json_schema"],
          "description": "The format type: 'text' (default), 'json_object' (any valid JSON), or 'json_schema' (JSON matching a schema)"
        },
        "json_schema": {
          "type": "object",
          "description": "Required when type is 'json_schema'",
          "properties": {
            "name": { "type": "string", "description": "Schema name identifier" },
            "description": { "type": "string" },
            "schema": { "type": "object", "description": "JSON Schema definition" },
            "strict": { "type": "boolean", "description": "Whether to enforce strict schema adherence" }
          },
          "required": ["name", "schema"]
        }
      },
      "required": ["type"]
    },

    "sessionConfig": {
      "type": "object",
      "properties": {
        "modalities": {
          "type": "array",
          "items": { "$ref": "#/definitions/modality" }
        },
        "instructions": { "type": "string" },
        "tools": { "type": "array" },
        "voice": { "$ref": "#/definitions/voiceConfig" },
        "input_audio_format": { "$ref": "#/definitions/audioFormat" },
        "output_audio_format": { "$ref": "#/definitions/audioFormat" },
        "response_format": { "$ref": "#/definitions/responseFormat" },
        "extensions": { "type": "object" }
      },
      "required": ["modalities"]
    },
    
    "contentDelta": {
      "type": "object",
      "properties": {
        "type": { "enum": ["text", "audio", "tool_call"] },
        "text": { "type": "string" },
        "audio": { "type": "string" },
        "tool_call": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "arguments": { "type": "string" }
          }
        }
      },
      "required": ["type"]
    },
    
    "contentItem": {
      "type": "object",
      "properties": {
        "type": { "enum": ["text", "audio", "image", "video", "file", "tool_call", "tool_result"] },
        "text": { "type": "string" },
        "audio": { "type": "string" },
        "image": { "type": "string" },
        "video": {
          "oneOf": [
            { "type": "string" },
            { "type": "object", "properties": { "url": { "type": "string" } } }
          ]
        },
        "file": {
          "oneOf": [
            { "type": "string" },
            { "type": "object", "properties": { "url": { "type": "string" } } }
          ]
        },
        "filename": { "type": "string" },
        "mime_type": { "type": "string" },
        "tool_call": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "arguments": { "type": "string" }
          }
        },
        "tool_result": {
          "type": "object",
          "properties": {
            "call_id": { "type": "string" },
            "result": { "type": "string" },
            "is_error": { "type": "boolean" }
          }
        }
      },
      "required": ["type"]
    },

    "message": {
      "type": "object",
      "properties": {
        "role": { "enum": ["system", "user", "assistant", "tool"] },
        "content": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "$ref": "#/definitions/contentItem" } }
          ]
        },
        "name": { "type": "string" },
        "tool_call_id": { "type": "string" },
        "tool_calls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "const": "function" },
              "function": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "arguments": { "type": "string" }
                },
                "required": ["name", "arguments"]
              }
            },
            "required": ["id", "type", "function"]
          }
        }
      },
      "required": ["role", "content"]
    },

    "usageStats": {
      "type": "object",
      "properties": {
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "cached_tokens": { "type": "integer" },
        "cost": {
          "type": "object",
          "properties": {
            "input_cost": { "type": "number" },
            "output_cost": { "type": "number" },
            "total_cost": { "type": "number" },
            "currency": { "type": "string" }
          }
        }
      }
    }
  },
  
  "oneOf": [
    {
      "title": "SessionCreateEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.create" },
            "uamp_version": { "type": "string" },
            "session": { "$ref": "#/definitions/sessionConfig" },
            "agent": { "type": "string", "description": "Agent name/ID this session targets" },
            "chat": { "type": "string", "description": "Chat ID when session is chat-scoped" },
            "token": { "type": "string", "description": "Per-session auth token" },
            "payment_token": { "type": "string", "description": "Per-session payment token" },
            "client_capabilities": { "type": "object" }
          },
          "required": ["type", "uamp_version"]
        }
      ]
    },
    {
      "title": "SessionCreatedEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.created" },
            "uamp_version": { "type": "string" },
            "session": { "type": "object" }
          },
          "required": ["type", "uamp_version", "session"]
        }
      ]
    },
    {
      "title": "InputTextEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.text" },
            "text": { "type": "string" },
            "role": { "enum": ["user", "system", "assistant"] },
            "messages": {
              "type": "array",
              "items": { "$ref": "#/definitions/message" },
              "description": "Full conversation history for stateless LLM context"
            },
            "payment_token": { "type": "string", "description": "Payment token for this interaction" },
            "context": {
              "type": "object",
              "properties": {
                "chat_id": { "type": "string" },
                "sender_id": { "type": "string" }
              },
              "description": "Routing and broadcast metadata"
            }
          },
          "required": ["type", "text"]
        }
      ]
    },
    {
      "title": "InputAudioEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.audio" },
            "audio": { "type": "string" },
            "format": { "$ref": "#/definitions/audioFormat" },
            "is_final": { "type": "boolean" }
          },
          "required": ["type", "audio", "format"]
        }
      ]
    },
    {
      "title": "InputImageEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.image" },
            "image": {
              "oneOf": [
                { "type": "string" },
                { "type": "object", "properties": { "url": { "type": "string" } } }
              ]
            },
            "format": { "enum": ["jpeg", "png", "webp", "gif"] },
            "detail": { "enum": ["low", "high", "auto"] }
          },
          "required": ["type", "image"]
        }
      ]
    },
    {
      "title": "ResponseCreateEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.create" },
            "response": { "type": "object" },
            "response_format": { "$ref": "#/definitions/responseFormat" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "ResponseDeltaEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.delta" },
            "response_id": { "type": "string" },
            "delta": { "$ref": "#/definitions/contentDelta" }
          },
          "required": ["type", "response_id", "delta"]
        }
      ]
    },
    {
      "title": "ResponseDoneEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.done" },
            "response_id": { "type": "string" },
            "response": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "status": { "enum": ["completed", "cancelled", "failed"] },
                "output": { "type": "array" },
                "usage": { "$ref": "#/definitions/usageStats" }
              }
            }
          },
          "required": ["type", "response_id", "response"]
        }
      ]
    },
    {
      "title": "ToolCallEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "tool.call" },
            "call_id": { "type": "string" },
            "name": { "type": "string" },
            "arguments": { "type": "string" }
          },
          "required": ["type", "call_id", "name", "arguments"]
        }
      ]
    },
    {
      "title": "ToolResultEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "tool.result" },
            "call_id": { "type": "string" },
            "result": { "type": "string" },
            "is_error": { "type": "boolean" }
          },
          "required": ["type", "call_id", "result"]
        }
      ]
    },
    {
      "title": "ProgressEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "progress" },
            "target": { "enum": ["tool", "response", "upload", "reasoning"] },
            "target_id": { "type": "string" },
            "stage": { "type": "string" },
            "message": { "type": "string" },
            "percent": { "type": "integer", "minimum": 0, "maximum": 100 },
            "step": { "type": "integer" },
            "total_steps": { "type": "integer" }
          },
          "required": ["type", "target"]
        }
      ]
    },
    {
      "title": "ThinkingEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "thinking" },
            "content": { "type": "string" },
            "stage": { "type": "string" },
            "redacted": { "type": "boolean" },
            "is_delta": { "type": "boolean" }
          },
          "required": ["type", "content"]
        }
      ]
    },
    {
      "title": "PingEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "ping" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "PongEvent",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "pong" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "InputTypingEvent",
      "description": "Client indicates user typing status",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.typing" },
            "is_typing": { "type": "boolean" },
            "chat_id": { "type": "string" }
          },
          "required": ["type", "is_typing"]
        }
      ]
    },
    {
      "title": "PresenceTypingEvent",
      "description": "Server broadcasts typing status from another participant",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "presence.typing" },
            "user_id": { "type": "string" },
            "username": { "type": "string" },
            "is_typing": { "type": "boolean" },
            "chat_id": { "type": "string" }
          },
          "required": ["type", "user_id", "is_typing"]
        }
      ]
    },
    {
      "title": "PaymentRequiredEvent",
      "description": "Server indicates payment is required to continue",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "payment.required" },
            "response_id": { "type": "string" },
            "requirements": {
              "type": "object",
              "properties": {
                "amount": { "type": "string" },
                "currency": { "type": "string" },
                "schemes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "scheme": { "enum": ["token", "crypto", "card", "ap2"] },
                      "network": { "type": "string" },
                      "address": { "type": "string" },
                      "min_amount": { "type": "string" },
                      "max_amount": { "type": "string" }
                    },
                    "required": ["scheme"]
                  }
                },
                "expires_at": { "type": "integer" },
                "reason": { "type": "string" },
                "ap2": {
                  "type": "object",
                  "description": "UCP/AP2 extension for commerce flows",
                  "properties": {
                    "mandate_uri": { "type": "string" },
                    "credential_types": { "type": "array", "items": { "type": "string" } },
                    "checkout_session_uri": { "type": "string" }
                  }
                }
              },
              "required": ["amount", "currency", "schemes"]
            }
          },
          "required": ["type", "requirements"]
        }
      ]
    },
    {
      "title": "PaymentSubmitEvent",
      "description": "Client submits payment token or proof",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "payment.submit" },
            "payment": {
              "type": "object",
              "properties": {
                "scheme": { "type": "string" },
                "network": { "type": "string" },
                "token": { "type": "string" },
                "proof": { "type": "string" },
                "amount": { "type": "string" },
                "ap2_credential": { "type": "object", "description": "UCP/AP2 verifiable credential" }
              },
              "required": ["scheme", "amount"]
            }
          },
          "required": ["type", "payment"]
        }
      ]
    },
    {
      "title": "PaymentAcceptedEvent",
      "description": "Server confirms payment was accepted",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "payment.accepted" },
            "payment_id": { "type": "string" },
            "balance_remaining": { "type": "string" },
            "expires_at": { "type": "integer" }
          },
          "required": ["type", "payment_id"]
        }
      ]
    },
    {
      "title": "PaymentBalanceEvent",
      "description": "Server sends balance update",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "payment.balance" },
            "balance": { "type": "string" },
            "currency": { "type": "string" },
            "low_balance_warning": { "type": "boolean" },
            "estimated_remaining": { "type": "integer" },
            "expires_at": { "type": "integer" }
          },
          "required": ["type", "balance", "currency"]
        }
      ]
    },
    {
      "title": "PaymentErrorEvent",
      "description": "Server reports payment error",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "payment.error" },
            "code": { 
              "enum": ["insufficient_balance", "token_expired", "token_invalid", "payment_failed", "rate_limited", "mandate_revoked"]
            },
            "message": { "type": "string" },
            "balance_required": { "type": "string" },
            "balance_current": { "type": "string" },
            "can_retry": { "type": "boolean" }
          },
          "required": ["type", "code", "message", "can_retry"]
        }
      ]
    },
    {
      "title": "SessionUpdateEvent",
      "description": "Client updates auth/payment token for a session without reconnect",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.update" },
            "session_id": { "type": "string" },
            "token": { "type": "string" },
            "payment_token": { "type": "string" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "SessionUpdatedEvent",
      "description": "Server confirms session update",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.updated" },
            "session_id": { "type": "string" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "MessageCreatedEvent",
      "description": "New chat message (chat UI use cases)",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "message.created" },
            "session_id": { "type": "string" },
            "message": { "type": "object" },
            "chat_id": { "type": "string" }
          },
          "required": ["type", "message"]
        }
      ]
    },
    {
      "title": "MessageReadEvent",
      "description": "Read receipt",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "message.read" },
            "session_id": { "type": "string" },
            "chat_id": { "type": "string" },
            "user_id": { "type": "string" },
            "last_read_at": { "type": "integer" }
          },
          "required": ["type", "chat_id", "user_id"]
        }
      ]
    },
    {
      "title": "PresenceOnlineEvent",
      "description": "User/agent came online",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "presence.online" },
            "user_id": { "type": "string" },
            "username": { "type": "string" }
          },
          "required": ["type", "user_id"]
        }
      ]
    },
    {
      "title": "PresenceOfflineEvent",
      "description": "User/agent went offline",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "presence.offline" },
            "user_id": { "type": "string" },
            "username": { "type": "string" }
          },
          "required": ["type", "user_id"]
        }
      ]
    },
    {
      "title": "SessionEndEvent",
      "description": "Either side ends a session",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.end" },
            "reason": { "type": "string", "description": "user_left, timeout, daemon_takeover, etc." }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "SessionErrorEvent",
      "description": "Session-level error",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "session.error" },
            "error": {
              "type": "object",
              "properties": {
                "code": { "type": "string", "description": "agent_offline, rate_limited, unauthorized, timeout" },
                "message": { "type": "string" },
                "details": {}
              },
              "required": ["code", "message"]
            }
          },
          "required": ["type", "error"]
        }
      ]
    },
    {
      "title": "InputVideoEvent",
      "description": "Video input",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.video" },
            "video": {
              "oneOf": [
                { "type": "string" },
                { "type": "object", "properties": { "url": { "type": "string" } } }
              ]
            },
            "format": { "enum": ["mp4", "webm"] }
          },
          "required": ["type", "video"]
        }
      ]
    },
    {
      "title": "InputFileEvent",
      "description": "File input",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "input.file" },
            "file": {
              "oneOf": [
                { "type": "string" },
                { "type": "object", "properties": { "url": { "type": "string" } } }
              ]
            },
            "filename": { "type": "string" },
            "mime_type": { "type": "string" }
          },
          "required": ["type", "file", "filename", "mime_type"]
        }
      ]
    },
    {
      "title": "ResponseCancelEvent",
      "description": "Cancel an in-progress response",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.cancel" },
            "response_id": { "type": "string" }
          },
          "required": ["type"]
        }
      ]
    },
    {
      "title": "ResponseCreatedEvent",
      "description": "Confirms a response has started",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.created" },
            "response_id": { "type": "string" }
          },
          "required": ["type", "response_id"]
        }
      ]
    },
    {
      "title": "ResponseErrorEvent",
      "description": "Response error",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
            "type": { "const": "response.error" },
            "response_id": { "type": "string" },
            "error": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": {}
              },
              "required": ["code", "message"]
            }
          },
          "required": ["type", "error"]
        }
      ]
    },
    {
      "title": "RateLimitEvent",
      "description": "Rate limit notification",
      "allOf": [
        { "$ref": "#/definitions/baseEvent" },
        {
          "properties": {
