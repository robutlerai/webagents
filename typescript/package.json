{
  "name": "webagents",
  "version": "0.3.5",
  "description": "TypeScript SDK for in-browser AI agents with UAMP protocol support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webagents": "./dist/cli/index.js",
    "robutler": "./dist/cli/robutler.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./uamp": {
      "import": "./dist/uamp/index.js",
      "types": "./dist/uamp/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    },
    "./skills/*": {
      "import": "./dist/skills/*/index.js",
      "types": "./dist/skills/*/index.d.ts"
    },
    "./skills/messaging/*": {
      "import": "./dist/skills/messaging/*/index.js",
      "types": "./dist/skills/messaging/*/index.d.ts"
    },
    "./skills/messaging/shared": {
      "import": "./dist/skills/messaging/shared/index.js",
      "types": "./dist/skills/messaging/shared/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./daemon": {
      "import": "./dist/daemon/index.js",
      "types": "./dist/daemon/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "tsc && node scripts/fix-extensions.mjs",
    "build": "tsc && node scripts/fix-extensions.mjs",
    "dev": "node scripts/dev-watch.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:gpu": "playwright test --project=chromium-gpu",
    "test:chrome": "playwright test --project=chrome-webgpu --headed",
    "test:server": "npx tsx tests/e2e/server.ts",
    "benchmark": "npx tsx tests/e2e/server.ts && echo '\\n📊 Open http://localhost:3456 in Chrome\\n'",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "pkg:webagents": "npx @yao-pkg/pkg dist/cli/index.js --target node20 --output ../../src-tauri/binaries/webagents",
    "pkg:robutler": "npx @yao-pkg/pkg dist/cli/robutler.js --target node20 --output ../../src-tauri/binaries/robutler",
    "pkg:all": "pnpm pkg:webagents && pnpm pkg:robutler"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "webllm",
    "transformers",
    "uamp",
    "browser",
    "webgpu"
  ],
  "author": "robutler.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robutlerai/webagents.git",
    "directory": "typescript"
  },
  "homepage": "https://robutler.ai/docs/webagents",
  "bugs": {
    "url": "https://github.com/robutlerai/webagents/issues"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^14.0.2",
    "hono": "^4.6.0",
    "jose": "^5.10.0",
    "readline-sync": "^1.4.10",
    "yaml": "^2.6.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "@huggingface/transformers": "^3.0.0",
    "@mlc-ai/web-llm": "^0.2.80",
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@mlc-ai/web-llm": {
      "optional": true
    },
    "@huggingface/transformers": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@huggingface/transformers": "^3.8.1",
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.1.37",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
