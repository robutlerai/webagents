{
  "provider": "google",
  "tests": [
    {
      "name": "simple_user_message",
      "input": {
        "messages": [
          {"role": "user", "content": "Hello"}
        ]
      },
      "expected": {
        "contents": [
          {"role": "user", "parts": [{"text": "Hello"}]}
        ]
      }
    },
    {
      "name": "system_message_to_system_instruction",
      "input": {
        "messages": [
          {"role": "system", "content": "You are helpful"},
          {"role": "user", "content": "Hi"}
        ]
      },
      "expected": {
        "system_parts": [{"text": "You are helpful"}],
        "contents": [
          {"role": "user", "parts": [{"text": "Hi"}]}
        ]
      }
    },
    {
      "name": "assistant_maps_to_model_role",
      "input": {
        "messages": [
          {"role": "user", "content": "Hi"},
          {"role": "assistant", "content": "Hello!"},
          {"role": "user", "content": "Bye"}
        ]
      },
      "expected": {
        "contents": [
          {"role": "user", "parts": [{"text": "Hi"}]},
          {"role": "model", "parts": [{"text": "Hello!"}]},
          {"role": "user", "parts": [{"text": "Bye"}]}
        ]
      }
    },
    {
      "name": "assistant_tool_calls_to_function_call",
      "description": "Both TS and Python adapters use native functionCall parts.",
      "input": {
        "messages": [
          {"role": "user", "content": "Weather?"},
          {
            "role": "assistant",
            "content": "",
            "tool_calls": [
              {
                "id": "call_1",
                "type": "function",
                "function": {"name": "get_weather", "arguments": "{\"city\":\"Tokyo\"}"}
              }
            ]
          }
        ]
      },
      "expected": {
        "contents": [
          {"role": "user", "parts": [{"text": "Weather?"}]},
          {"role": "model", "parts": [{"functionCall": {"name": "get_weather", "args": {"city": "Tokyo"}}}]}
        ]
      }
    },
    {
      "name": "tool_result_to_function_response",
      "description": "Both TS and Python adapters use native functionCall/functionResponse.",
      "input": {
        "messages": [
          {"role": "user", "content": "Weather?"},
          {
            "role": "assistant",
            "content": "",
            "tool_calls": [
              {
                "id": "call_1",
                "type": "function",
                "function": {"name": "get_weather", "arguments": "{\"city\":\"LA\"}"}
              }
            ]
          },
          {"role": "tool", "content": "{\"temp\":\"25C\"}", "tool_call_id": "call_1"}
        ]
      },
      "expected": {
        "contents": [
          {"role": "user", "parts": [{"text": "Weather?"}]},
          {"role": "model", "parts": [{"functionCall": {"name": "get_weather", "args": {"city": "LA"}}}]},
          {"role": "user", "parts": [{"functionResponse": {"name": "call_1", "id": "call_1", "response": {"result": {"temp": "25C"}}}}]}
        ]
      }
    },
    {
      "name": "tool_result_plain_text",
      "description": "Both TS and Python adapters use native functionResponse.",
      "input": {
        "messages": [
          {"role": "tool", "content": "sunny and warm", "tool_call_id": "fn_1"}
        ]
      },
      "expected": {
        "contents": [
          {"role": "user", "parts": [{"functionResponse": {"name": "fn_1", "id": "fn_1", "response": {"result": "sunny and warm"}}}]}
        ]
      }
    }
  ],
  "tool_tests": [
    {
      "name": "openai_tools_to_function_declarations",
      "input": [
        {
          "type": "function",
          "function": {
            "name": "get_weather",
            "description": "Get weather",
            "parameters": {"type": "object", "properties": {"city": {"type": "string"}}}
          }
        }
      ],
      "expected": [
        {
          "function_declarations": [
            {
              "name": "get_weather",
              "description": "Get weather",
              "parameters": {"type": "object", "properties": {"city": {"type": "string"}}}
            }
          ]
        }
      ]
    },
    {
      "name": "native_tool_google_search",
      "input": [
        {"type": "google_search"}
      ],
      "expected": [
        {"google_search": {}}
      ]
    },
    {
      "name": "mixed_function_and_native_tools",
      "input": [
        {
          "type": "function",
          "function": {
            "name": "calc",
            "description": "Calculate",
            "parameters": {"type": "object", "properties": {}}
          }
        },
        {"type": "code_execution"},
        {"type": "url_context"}
      ],
      "expected": [
        {
          "function_declarations": [
            {
              "name": "calc",
              "description": "Calculate",
              "parameters": {"type": "object", "properties": {}}
            }
          ]
        },
        {"code_execution": {}},
        {"url_context": {}}
      ]
    },
    {
      "name": "native_only_multiple",
      "input": [
        {"type": "code_execution"},
        {"type": "google_search"}
      ],
      "expected": [
        {"code_execution": {}},
        {"google_search": {}}
      ]
    }
  ]
}
